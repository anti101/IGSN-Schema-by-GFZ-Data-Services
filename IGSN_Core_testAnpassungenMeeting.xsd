<?xml version="1.0" encoding="UTF-8"?><!-- bearbeitet mit XMLSpy v2026 (x64) (https://www.altova.com) von TTanja (Schule) --><xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:igsn="http://pmd.gfz-potsdam.de/igsn/schemas/description-ext/1.3" xmlns:daci="http://datacite.org/schema/kernel-4" targetNamespace="http://pmd.gfz-potsdam.de/igsn/schemas/description-ext/1.3" elementFormDefault="qualified">	<xs:import namespace="http://datacite.org/schema/kernel-4" schemaLocation="X:\IGSN\DataCiteSchema4-7\kernel-4.7\metadata.xsd"/>	<xs:element name="resource">		<xs:annotation>			<xs:documentation>Root element of a single record. This wrapper element is for XML implementation only 				and is not defined in the IGSN metadata schema.			</xs:documentation>		</xs:annotation>		<xs:complexType>			<xs:sequence>				<xs:element name="identifier">					<xs:annotation>						<xs:documentation>The Identifier is a unique string that identifies a resource. IGSN (International GeoSample Number) registered by an IGSN member.</xs:documentation>						<xs:appinfo>test</xs:appinfo>					</xs:annotation>					<xs:complexType>						<xs:simpleContent>							<xs:extension base="xs:string">								<xs:attribute name="identifierType" use="required" fixed="IGSN">									<xs:annotation>										<xs:documentation>The type of Identifier.</xs:documentation>									</xs:annotation>									<xs:simpleType>										<xs:restriction base="xs:string">											<xs:enumeration value="IGSN"/>											<xs:enumeration value="DOI"/>										</xs:restriction>									</xs:simpleType>								</xs:attribute>								<xs:attribute name="resourceTypeGeneral" type="daci:resourceType" use="required" fixed="PhysicalObject"/>							</xs:extension>						</xs:simpleContent>					</xs:complexType>				</xs:element>				<xs:element name="archive" minOccurs="0" maxOccurs="unbounded">					<xs:annotation>						<xs:documentation>Name of institution, museum, or repository where the sample was originally stored (see archive list)</xs:documentation>					</xs:annotation>					<xs:complexType>						<xs:sequence>							<xs:element name="affiliation" type="daci:affiliation">								<xs:annotation>									<xs:documentation>The contributor’s nameType may be Organizational or Personal. In the case of an organizational contributor, e.g., a research group, this will often be the name of the institution to which that organization belongs.</xs:documentation>								</xs:annotation>							</xs:element>						</xs:sequence>						<xs:attribute name="lang" fixed="en">							<xs:annotation>								<xs:documentation>distinguishes the language</xs:documentation>							</xs:annotation>							<xs:simpleType>								<xs:restriction base="xs:language">									<xs:enumeration value="en"/>								</xs:restriction>							</xs:simpleType>						</xs:attribute>						<xs:attribute name="sampleAccess" use="optional">							<xs:annotation>								<xs:documentation>The sample access status provides information about the status of the sample; it may be freely accessible, accessible under certain conditions, or generally inaccessible. It is also possible to indicate whether the sample has been destroyed, for those to whom it relates</xs:documentation>							</xs:annotation>							<xs:simpleType>								<xs:restriction base="xs:string">									<xs:enumeration value="public"/>									<xs:enumeration value="private"/>									<xs:enumeration value="restricted"/>									<xs:enumeration value="destroyed"/>									<xs:enumeration value="discarded"/>								</xs:restriction>							</xs:simpleType>						</xs:attribute>						<xs:attribute name="archiveIdentifier"/>					</xs:complexType>				</xs:element>				<xs:element name="language" type="xs:language" minOccurs="0">					<xs:annotation>						<xs:documentation>Primary language of the resource. Allowed values are taken from  IETF BCP 47, ISO 639-1 language codes.</xs:documentation>					</xs:annotation>				</xs:element>				<xs:element name="name" maxOccurs="unbounded">					<xs:annotation>						<xs:documentation>This element is used to name and identify a resource in a technical and linguistic context. It refers to the resource by its common name and is designed to be readable by humans. The name element should be used when the common name of the resource must be specified. The primary name of the resource should be entered. Variant spellings, abbreviated forms or alternative names should only be used if they correspond to the officially used or technically authoritative name. The element does not need to be unique and may occur multiple times.</xs:documentation>						<xs:documentation>Collector's or contributor's local/field name used to name the specimen; not globally unique but typically unique within a set of specimens</xs:documentation>					</xs:annotation>					<xs:complexType>						<xs:simpleContent>							<xs:extension base="xs:string">								<xs:attribute name="titleType" type="daci:titleType">									<xs:annotation>										<xs:documentation>This attribute is used to specify the type of entry contained within the "name" element.</xs:documentation>									</xs:annotation>								</xs:attribute>								<xs:attribute name="lang" fixed="en">									<xs:annotation>										<xs:documentation>distinguishes the language</xs:documentation>									</xs:annotation>									<xs:simpleType>										<xs:restriction base="xs:language">											<xs:enumeration value="en"/>										</xs:restriction>									</xs:simpleType>								</xs:attribute>							</xs:extension>						</xs:simpleContent>					</xs:complexType>				</xs:element>				<xs:element name="relationshipIdentifiers" minOccurs="0">					<xs:annotation>						<xs:documentation>wrapper to sort all identifiers representing resources having a relation to the registed resource</xs:documentation>					</xs:annotation>					<xs:complexType>						<xs:sequence>							<xs:element name="alternateIdentifier" minOccurs="0" maxOccurs="unbounded">								<xs:annotation>									<xs:documentation>Identifiers other than the primary Identifier applied to the resource being registered. This may be any alphanumeric string which is unique within its domain of use. May be used for local identifiers. AlternateIdentifier should be used for another identifier of the same instance (same location, same file).</xs:documentation>								</xs:annotation>								<xs:complexType>									<xs:simpleContent>										<xs:extension base="xs:string">											<xs:attribute name="alternateIdentifierType" type="xs:string" use="required">												<xs:annotation>													<xs:documentation>The type of the alternateIdentifier</xs:documentation>												</xs:annotation>											</xs:attribute>										</xs:extension>									</xs:simpleContent>								</xs:complexType>							</xs:element>							<xs:element name="parentIdentifier" minOccurs="0">								<xs:annotation>									<xs:documentation>IGSN of a resource from which this resource derives</xs:documentation>								</xs:annotation>								<xs:complexType>									<xs:simpleContent>										<xs:extension base="xs:anyURI">											<xs:attribute name="identifierType" type="daci:relatedIdentifierType" use="required" fixed="IGSN">												<xs:annotation>													<xs:documentation>type of the Identifier, since it must be an IGSN, this value is fixed</xs:documentation>												</xs:annotation>											</xs:attribute>											<xs:attribute name="relationType" type="daci:relationType" use="required" fixed="IsPartOf">												<xs:annotation>													<xs:documentation>This attribute is used to specify, in a machine-readable and standardised manner, the relationship between the resource specified in the element and the resource described here.</xs:documentation>												</xs:annotation>											</xs:attribute>										</xs:extension>									</xs:simpleContent>								</xs:complexType>							</xs:element>							<xs:element name="relatedIdentifier" minOccurs="0" maxOccurs="unbounded">								<xs:annotation>									<xs:documentation>Identifiers of related resources. These must be globally unique identifiers.</xs:documentation>								</xs:annotation>								<xs:complexType>									<xs:simpleContent>										<xs:extension base="xs:string">											<xs:attribute name="identifierType" type="daci:relatedIdentifierType" use="required">												<xs:annotation>													<xs:documentation>type of the Identifier,</xs:documentation>												</xs:annotation>											</xs:attribute>											<xs:attribute name="relationType" type="daci:relationType" use="required">												<xs:annotation>													<xs:documentation>This attribute is used to specify, in a machine-readable and standardised manner, the relationship between the resource specified in the element and the resource described here.</xs:documentation>												</xs:annotation>											</xs:attribute>										</xs:extension>									</xs:simpleContent>								</xs:complexType>							</xs:element>						</xs:sequence>					</xs:complexType>				</xs:element>				<xs:element name="agents">					<xs:annotation>						<xs:documentation>A wrapper element that bundles all elements relating to specific persons</xs:documentation>					</xs:annotation>					<xs:complexType>						<xs:sequence>							<xs:element name="creator" minOccurs="1" maxOccurs="unbounded">								<xs:annotation>									<xs:documentation>"The creator wrapper contains a list of “the main researcher(s) involved...in priority order.” For IGSN IDs, this could be the sample collector/creator, chief scientist, curator, or even the person who deposited the sample into a repository.As a norm, IGSN ID registrants are expected to collect information about the sample owner, Principle Investigator, and/or otherwise. However, if no appropriate name is available, the property will be populated with the name of the IGSN ID Repository registrant"</xs:documentation>								</xs:annotation>								<xs:complexType>									<xs:sequence>										<xs:element name="creatorName" minOccurs="1" maxOccurs="1">											<xs:annotation>												<xs:documentation>full Name of the creator</xs:documentation>											</xs:annotation>											<xs:complexType>												<xs:simpleContent>													<xs:extension base="xs:string">														<xs:attribute name="nameType" type="daci:nameType" use="required">															<xs:annotation>																<xs:documentation>Type of creator or contributer, "personal" for persons or "organiszational" for Institutions</xs:documentation>															</xs:annotation>														</xs:attribute>														<xs:attribute name="lang" fixed="en">															<xs:annotation>																<xs:documentation>distinguishes the language</xs:documentation>															</xs:annotation>															<xs:simpleType>																<xs:restriction base="xs:language">																	<xs:enumeration value="en"/>																</xs:restriction>															</xs:simpleType>														</xs:attribute>													</xs:extension>												</xs:simpleContent>											</xs:complexType>										</xs:element>										<xs:element name="givenName" type="xs:string">											<xs:annotation>												<xs:documentation>Given Name of the Person</xs:documentation>											</xs:annotation>										</xs:element>										<xs:element name="familyName" type="xs:string">											<xs:annotation>												<xs:documentation>Family Name of the Person</xs:documentation>											</xs:annotation>										</xs:element>										<xs:element name="nameIdentifier" type="daci:nameIdentifier" minOccurs="0">											<xs:annotation>												<xs:documentation>Uniquely identifies an individual or legal entity, according to various schemes. ORCID is pref for Person ROR is pref for Organizations</xs:documentation>											</xs:annotation>										</xs:element>										<xs:element name="affiliation" type="daci:affiliation">											<xs:annotation>												<xs:documentation>The organizational or institutional affiliation of the creator.</xs:documentation>											</xs:annotation>										</xs:element>									</xs:sequence>									<xs:attribute name="creatorType" use="required">										<xs:annotation>											<xs:documentation>funktion of the creator regarding the projekt</xs:documentation>										</xs:annotation>										<xs:simpleType>											<xs:restriction base="xs:string">												<xs:enumeration value="collector"/>												<xs:enumeration value="creator"/>											</xs:restriction>										</xs:simpleType>									</xs:attribute>								</xs:complexType>							</xs:element>							<xs:element name="contributor" minOccurs="0" maxOccurs="unbounded">								<xs:annotation>									<xs:documentation>The institution or person responsible for collecting, managing, distributing, or otherwise contributing to the development of the resource. To supply multiple contributors, repeat this property.</xs:documentation>								</xs:annotation>								<xs:complexType>									<xs:sequence>										<xs:element name="contributorName">											<xs:annotation>												<xs:documentation>full name</xs:documentation>											</xs:annotation>											<xs:complexType>												<xs:simpleContent>													<xs:extension base="xs:string">														<xs:attribute name="nameType" type="daci:nameType" use="required">															<xs:annotation>																<xs:documentation>type of the contributer. Contributers may be persons or institutions.</xs:documentation>															</xs:annotation>														</xs:attribute>														<xs:attribute name="lang" fixed="en">															<xs:annotation>																<xs:documentation>distinguishes the language</xs:documentation>															</xs:annotation>															<xs:simpleType>																<xs:restriction base="xs:language">																	<xs:enumeration value="en"/>																</xs:restriction>															</xs:simpleType>														</xs:attribute>													</xs:extension>												</xs:simpleContent>											</xs:complexType>										</xs:element>										<xs:element name="givenName" type="xs:string">											<xs:annotation>												<xs:documentation>Given Name of the Person</xs:documentation>											</xs:annotation>										</xs:element>										<xs:element name="familyName" type="xs:string">											<xs:annotation>												<xs:documentation>Family Name of the Person</xs:documentation>											</xs:annotation>										</xs:element>										<xs:element name="nameIdentifier" type="daci:nameIdentifier" minOccurs="0">											<xs:annotation>												<xs:documentation>Uniquely identifies an individual or legal entity, according to various schemes.</xs:documentation>											</xs:annotation>										</xs:element>										<xs:element name="affiliation" type="daci:affiliation">											<xs:annotation>												<xs:documentation>The contributor’s nameType may be Organizational or Personal. In the case of an organizational contributor, e.g., a research group, this will often be the name of the institution to which that organization belongs.</xs:documentation>											</xs:annotation>										</xs:element>									</xs:sequence>									<xs:attribute name="contributorType" type="daci:contributorType">										<xs:annotation>											<xs:documentation>The type of contributor of the resource.</xs:documentation>										</xs:annotation>									</xs:attribute>								</xs:complexType>							</xs:element>							<xs:element name="publisher">								<xs:annotation>									<xs:documentation>The full name of the entity that holds, archives, publishes, prints, distributes, releases, issues or produces the resource. This property will be used to create the citation, so consider the importance of the role.</xs:documentation>								</xs:annotation>								<xs:complexType>									<xs:simpleContent>										<xs:extension base="xs:string">											<xs:attribute name="publisherIdentifier" type="xs:anyURI" use="required">												<xs:annotation>													<xs:documentation>Uniquely identifies the publisher, according to various schemes.</xs:documentation>												</xs:annotation>											</xs:attribute>											<xs:attribute name="publisherIdentifierScheme" use="required">												<xs:simpleType>													<xs:restriction base="xs:string">														<xs:enumeration value="ROR"/>														<xs:enumeration value="re3data"/>														<xs:enumeration value="VIAF"/>														<xs:enumeration value="Wikidata"/>														<xs:enumeration value="Crossref Funder ID"/>														<xs:enumeration value="ISNI"/>														<xs:enumeration value="OpenDOAR"/>														<xs:enumeration value="FAIRsharing"/>														<xs:enumeration value="ISSN"/>													</xs:restriction>												</xs:simpleType>											</xs:attribute>											<xs:attribute name="schemeURI" type="xs:anyURI" use="required"/>											<xs:attribute name="lang" fixed="en">												<xs:annotation>													<xs:documentation>distinguishes the language</xs:documentation>												</xs:annotation>												<xs:simpleType>													<xs:restriction base="xs:language">														<xs:enumeration value="en"/>													</xs:restriction>												</xs:simpleType>											</xs:attribute>										</xs:extension>									</xs:simpleContent>								</xs:complexType>							</xs:element>						</xs:sequence>					</xs:complexType>				</xs:element>				<xs:element name="geoLocations" minOccurs="0" maxOccurs="unbounded">					<xs:annotation>						<xs:documentation>Spatial region or named place where the sample was gathered</xs:documentation>					</xs:annotation>					<xs:complexType>						<xs:sequence>							<xs:element name="geoLocationPlace" minOccurs="0" maxOccurs="unbounded">								<xs:annotation>									<xs:documentation>"Where was the sample acquired relative to the Earth (or another celestial body...). Some samples might be 'non-geographic': mineral specimen, synthetic material. Spatial region or named place where the data was gathered or about which the data is focused."</xs:documentation>								</xs:annotation>								<xs:complexType>									<xs:simpleContent>										<xs:extension base="xs:string">											<xs:attribute name="lang" fixed="en">												<xs:annotation>													<xs:documentation>distinguishes the language</xs:documentation>												</xs:annotation>												<xs:simpleType>													<xs:restriction base="xs:language">														<xs:enumeration value="en"/>													</xs:restriction>												</xs:simpleType>											</xs:attribute>										</xs:extension>									</xs:simpleContent>								</xs:complexType>							</xs:element>							<xs:element name="coordinateSystem" default="WGS84">								<xs:simpleType>									<xs:restriction base="xs:string">										<xs:enumeration value="WGS84"/>									</xs:restriction>								</xs:simpleType>							</xs:element>							<xs:element name="geoLocationPoint" type="daci:point" minOccurs="0" maxOccurs="1">								<xs:annotation>									<xs:documentation>a geographical point described by a single pair of latitude and longitude coordinates</xs:documentation>								</xs:annotation>							</xs:element>							<xs:element name="geoLocationBox" type="daci:box" minOccurs="0" maxOccurs="1">								<xs:annotation>									<xs:documentation>"A box is defined by two geographic points. Left low corner and right upper corner. Each point is defined by its longitude and latitude.Use WGS 84 (World Geodetic System) coordinates and use only decimal numbers for coordinates."</xs:documentation>								</xs:annotation>							</xs:element>							<xs:element name="geoLocationPolygon" minOccurs="0">								<xs:annotation>									<xs:documentation>A drawn polygon area, defined by a set of points and lines connecting the points in a closed chain. A polygon is delimited by geographic points. Each point is defined by a longitude-latitude pair. The last point should be the same as the first point.</xs:documentation>								</xs:annotation>								<xs:complexType>									<xs:sequence>										<xs:element name="polygonPoint" type="daci:point" minOccurs="4" maxOccurs="unbounded"/>									</xs:sequence>								</xs:complexType>							</xs:element>						</xs:sequence>					</xs:complexType>				</xs:element>				<xs:element name="entityTypeClassifications">					<xs:annotation>						<xs:documentation>							Wrapper to hold all material and classification information about the resource						</xs:documentation>					</xs:annotation>					<xs:complexType>						<xs:sequence>							<xs:element name="resourceType">								<xs:simpleType>									<xs:restriction base="xs:string">										<xs:enumeration value="Feature"/>										<xs:enumeration value="Sample"/>										<xs:enumeration value="Collection"/>									</xs:restriction>								</xs:simpleType>							</xs:element>							<xs:element name="samleType"/>							<xs:element name="sampleTypeClassificationPlaceholder"/>							<xs:element name="classification" minOccurs="0" maxOccurs="unbounded">								<xs:complexType>									<xs:simpleContent>										<xs:extension base="xs:string">											<xs:attribute name="subjectScheme" type="xs:string" use="optional"/>											<xs:attribute name="schemeURI" type="xs:anyURI" use="optional"/>											<xs:attribute name="valueURI" type="xs:anyURI" use="optional"/>											<xs:attribute name="classificationCode" type="xs:string" 