<?xml version="1.0" encoding="UTF-8"?><!-- bearbeitet mit XMLSpy v2026 (x64) (https://www.altova.com) von TTanja (Schule) --><xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:igsn="http://pmd.gfz-potsdam.de/igsn/schemas/description-ext/1.3" xmlns:daci="http://datacite.org/schema/kernel-4" targetNamespace="http://pmd.gfz-potsdam.de/igsn/schemas/description-ext/1.3" elementFormDefault="qualified">	<xs:import namespace="http://datacite.org/schema/kernel-4" schemaLocation="X:\IGSN\DataCiteSchema4-7\kernel-4.7\metadata.xsd"/>	<xs:element name="resource">		<xs:annotation>			<xs:documentation>Root element of a single record. This wrapper element is for XML implementation only 				and is not defined in the IGSN metadata schema.			</xs:documentation>		</xs:annotation>		<xs:complexType>			<xs:sequence>				<xs:element name="identifier">					<xs:annotation>						<xs:documentation>The Identifier is a unique string that identifies a resource.		</xs:documentation>						<xs:appinfo>test</xs:appinfo>					</xs:annotation>					<xs:complexType>						<xs:simpleContent>							<xs:extension base="xs:string">								<xs:attribute name="identifierType" use="required" fixed="IGSN">									<xs:annotation>										<xs:documentation>As this schema is used to register IGSNs only, this attribute is pre-set to ‘IGSN’</xs:documentation>									</xs:annotation>									<xs:simpleType>										<xs:restriction base="xs:string">											<xs:enumeration value="IGSN"/>										</xs:restriction>									</xs:simpleType>								</xs:attribute>								<xs:attribute name="sampleAccess" use="optional">									<xs:annotation>										<xs:documentation>This attribute allows you to set the sample's access level. Indicates whether this resource is available for reuse beyond the original contributor. Typically only used for samples, not sampling features. The available options are "public", "restricted", "private" and "destroyed".</xs:documentation>									</xs:annotation>									<xs:simpleType>										<xs:restriction base="xs:string">											<xs:enumeration value="public"/>											<xs:enumeration value="private"/>											<xs:enumeration value="restricted"/>											<xs:enumeration value="destroyed"/>										</xs:restriction>									</xs:simpleType>								</xs:attribute>								<xs:attribute name="resourceTypeGeneral" type="daci:resourceType" use="required" fixed="PhysicalObject"/>							</xs:extension>						</xs:simpleContent>					</xs:complexType>				</xs:element>				<xs:element name="currentArchive" minOccurs="0">					<xs:annotation>						<xs:documentation>Name of the institution, museum or repository where the sample is currently stored A list of available archives is available at: https://app.geosamples.org/reference/advanced_list.php?srv=archive</xs:documentation>					</xs:annotation>					<xs:complexType>						<xs:simpleContent>							<xs:extension base="xs:string">								<xs:attribute name="lang" fixed="en">									<xs:annotation>										<xs:documentation>The language of the archive name</xs:documentation>									</xs:annotation>									<xs:simpleType>										<xs:restriction base="xs:language">											<xs:enumeration value="en"/>										</xs:restriction>									</xs:simpleType>								</xs:attribute>							</xs:extension>						</xs:simpleContent>					</xs:complexType>				</xs:element>				<xs:element name="originalArchive" minOccurs="0">					<xs:annotation>						<xs:documentation>Name of the institution, museum or repository where the sample was originally storedA list of available archives is available at: https://app.geosamples.org/reference/advanced_list.php?srv=archive</xs:documentation>					</xs:annotation>					<xs:complexType>						<xs:simpleContent>							<xs:extension base="xs:string">								<xs:attribute name="lang" fixed="en">									<xs:annotation>										<xs:documentation>The language of the archive name</xs:documentation>									</xs:annotation>									<xs:simpleType>										<xs:restriction base="xs:language">											<xs:enumeration value="en"/>										</xs:restriction>									</xs:simpleType>								</xs:attribute>							</xs:extension>						</xs:simpleContent>					</xs:complexType>				</xs:element>				<xs:element name="language" type="xs:language" minOccurs="0">					<xs:annotation>						<xs:documentation>Primary language of the resource. Allowed values are taken from  IETF BCP 47, ISO 639-1 language codes.</xs:documentation>					</xs:annotation>				</xs:element>				<xs:element name="name" maxOccurs="unbounded">					<xs:annotation>						<xs:documentation>Text string for people to understand what is identified. What would typically be presented in a user interface. name of the sample in the local system / ELN or other kinds of sample management system</xs:documentation>						<xs:documentation>Collector's or contributor's local/field name used to name the specimen; not globally unique but typically unique within a set of specimens</xs:documentation>					</xs:annotation>					<xs:complexType>						<xs:simpleContent>							<xs:extension base="xs:string">								<xs:attribute name="titleType" type="daci:titleType">									<xs:annotation>										<xs:documentation>The titleType attribute is required if there is more than one title. A main title is required for registration; this does not contain an attribute. An attribute must be set for each additional title in order to correctly indicate the hierarchy between the titles. As the titles expected here are local sample names, the value of the attribute is set to ‘other’ by default.</xs:documentation>									</xs:annotation>								</xs:attribute>								<xs:attribute name="lang" fixed="en">									<xs:annotation>										<xs:documentation>The language of the name.</xs:documentation>									</xs:annotation>									<xs:simpleType>										<xs:restriction base="xs:language">											<xs:enumeration value="en"/>										</xs:restriction>									</xs:simpleType>								</xs:attribute>							</xs:extension>						</xs:simpleContent>					</xs:complexType>				</xs:element>				<xs:element name="relationshipIdentifiers" minOccurs="0">					<xs:annotation>						<xs:documentation>The wrapper is used to sort all identifiers representing resources that have a relation to the registered resource						</xs:documentation>					</xs:annotation>					<xs:complexType>						<xs:sequence>							<xs:element name="alternateIdentifier" minOccurs="0" maxOccurs="unbounded">								<xs:annotation>									<xs:documentation>Identifiers other than the primary Identifier applied to the resource being registered. This may be any alphanumeric string which is unique within its domain of issue. May be used for local identifiers. AlternateIdentifier should be used for another identifier of the same instance (same location, same file). If alternateIdentifier is used, alternateIdentifierType is mandatory.</xs:documentation>								</xs:annotation>								<xs:complexType>									<xs:simpleContent>										<xs:extension base="xs:string">											<xs:attribute name="alternateIdentifierType" type="xs:string" use="required">												<xs:annotation>													<xs:documentation>The type of the AlternateIdentifier. If alternateIdentifier is used, alternateIdentifierType is mandatory.</xs:documentation>												</xs:annotation>											</xs:attribute>										</xs:extension>									</xs:simpleContent>								</xs:complexType>							</xs:element>							<xs:element name="parentIdentifier" minOccurs="0">								<xs:annotation>									<xs:documentation>IGSN of a resource from which this resource derives;</xs:documentation>								</xs:annotation>								<xs:complexType>									<xs:simpleContent>										<xs:extension base="xs:anyURI">											<xs:attribute name="identifierType" type="daci:relatedIdentifierType" use="required" fixed="IGSN">												<xs:annotation>													<xs:documentation>type of the Identifier, since it must be an IGSN, this value is fixed</xs:documentation>												</xs:annotation>											</xs:attribute>											<xs:attribute name="relationType" type="daci:relationType" use="required" fixed="IsPartOf">												<xs:annotation>													<xs:documentation>type of retation, since this element is abot the parent of the resouce, the value is fixed to "isPartOf"</xs:documentation>												</xs:annotation>											</xs:attribute>										</xs:extension>									</xs:simpleContent>								</xs:complexType>							</xs:element>							<xs:element name="relatedIdentifier" minOccurs="0" maxOccurs="unbounded">								<xs:annotation>									<xs:documentation>dentifiers of related resources. These must be globally unique identifiers.</xs:documentation>								</xs:annotation>								<xs:complexType>									<xs:simpleContent>										<xs:extension base="xs:string">											<xs:attribute name="identifierType" type="daci:relatedIdentifierType" use="required"/>											<xs:attribute name="relationType" type="daci:relationType" use="required"/>										</xs:extension>									</xs:simpleContent>								</xs:complexType>							</xs:element>						</xs:sequence>					</xs:complexType>				</xs:element>				<xs:element name="agents">					<xs:annotation>						<xs:documentation>			Wrapper so that all people and organisations appear in one place.						</xs:documentation>					</xs:annotation>					<xs:complexType>						<xs:sequence>							<xs:element name="creator" minOccurs="1" maxOccurs="unbounded">								<xs:annotation>									<xs:documentation>"The creator property contains a list of “the main researcher(s) involved...in priority order.” For IGSN IDs, this could be the sample collector/creator, chief scientist, curator, or even the person who deposited the sample into a repository.As a norm, IGSN ID registrants are expected to collect information about the sample owner, Principle Investigator, and/or otherwise. However, if no appropriate name is available, the property will be populated with the name of the IGSN ID Repository registrant"</xs:documentation>								</xs:annotation>								<xs:complexType>									<xs:sequence>										<xs:element name="creatorName" minOccurs="1" maxOccurs="1">											<xs:annotation>												<xs:documentation>											The creator's full name. In the format: Surname, First name												</xs:documentation>											</xs:annotation>											<xs:complexType>												<xs:simpleContent>													<xs:extension base="xs:string">														<xs:attribute name="nameType" type="daci:nameType" use="required">															<xs:annotation>																<xs:documentation>Type of Name, "personal" for persons or "organiszational" for Institutions</xs:documentation>															</xs:annotation>														</xs:attribute>														<xs:attribute name="creatorType" use="required">															<xs:annotation>																<xs:documentation>funktion of the person regarding the projekt. This type is used to build the LPs and credit the persons according to they´re function</xs:documentation>															</xs:annotation>															<xs:simpleType>																<xs:restriction base="xs:string">																	<xs:enumeration value="collector"/>																	<xs:enumeration value="creator"/>																</xs:restriction>															</xs:simpleType>														</xs:attribute>														<xs:attribute name="lang" fixed="en">															<xs:annotation>																<xs:documentation> The language of the creator name For creator names, xml:lang is recommended only when nameType is “Organizational”.</xs:documentation>															</xs:annotation>															<xs:simpleType>																<xs:restriction base="xs:language">																	<xs:enumeration value="en"/>																</xs:restriction>															</xs:simpleType>														</xs:attribute>													</xs:extension>												</xs:simpleContent>											</xs:complexType>										</xs:element>										<xs:element name="givenName" type="xs:string">											<xs:annotation>												<xs:documentation>Given Name of the Person</xs:documentation>											</xs:annotation>										</xs:element>										<xs:element name="familyName" type="xs:string">											<xs:annotation>												<xs:documentation>Family Name of the Person</xs:documentation>											</xs:annotation>										</xs:element>										<xs:element name="nameIdentifier" type="daci:nameIdentifier">											<xs:annotation>												<xs:documentation>Uniquely identifies an individual or legal entity, according to various schemes. ORCID is pref for Person ROR is pref for Organizations</xs:documentation>											</xs:annotation>										</xs:element>										<xs:element name="affiliation" type="daci:affiliation">											<xs:annotation>												<xs:documentation>Name of the institution to which the collector is affiliated</xs:documentation>											</xs:annotation>										</xs:element>									</xs:sequence>								</xs:complexType>							</xs:element>							<xs:element name="contributor" minOccurs="0" maxOccurs="unbounded">								<xs:annotation>									<xs:documentation>The institution or person responsible for collecting, managing, distributing, or otherwise contributing to the development of the resource. To supply multiple contributors, repeat this property.</xs:documentation>								</xs:annotation>								<xs:complexType>									<xs:sequence>										<xs:element name="contributorName">											<xs:annotation>												<xs:documentation>full name</xs:documentation>											</xs:annotation>											<xs:complexType>												<xs:simpleContent>													<xs:extension base="xs:string">														<xs:attribute name="nameType" type="daci:nameType" use="required">															<xs:annotation>																<xs:documentation>type of the contributer. Contributers may be persons or institutions.</xs:documentation>															</xs:annotation>														</xs:attribute>														<xs:attribute name="lang" fixed="en">															<xs:simpleType>																<xs:restriction base="xs:language">																	<xs:enumeration value="en"/>																</xs:restriction>															</xs:simpleType>														</xs:attribute>													</xs:extension>												</xs:simpleContent>											</xs:complexType>										</xs:element>										<xs:element name="givenName" type="xs:string">											<xs:annotation>												<xs:documentation>Given Name of the Person</xs:documentation>											</xs:annotation>										</xs:element>										<xs:element name="familyName" type="xs:string">											<xs:annotation>												<xs:documentation>Family Name of the Person</xs:documentation>											</xs:annotation>										</xs:element>										<xs:element name="nameIdentifier" type="daci:nameIdentifier">											<xs:annotation>												<xs:documentation>Uniquely identifies an individual or legal entity, according to various schemes.</xs:documentation>											</xs:annotation>										</xs:element>										<xs:element name="affiliation" type="daci:affiliation">											<xs:annotation>												<xs:documentation>The contributor’s nameType may be Organizational or Personal. In the case of an organizational contributor, e.g., a research group, this will often be the name of the institution to which that organization belongs.</xs:documentation>											</xs:annotation>										</xs:element>									</xs:sequence>									<xs:attribute name="contributorType" type="daci:contributorType">										<xs:annotation>											<xs:documentation>The type of contributor of the resource.</xs:documentation>										</xs:annotation>									</xs:attribute>								</xs:complexType>							</xs:element>							<xs:element name="publisher">								<xs:annotation>									<xs:documentation>The name of the entity that holds, archives, publishes, prints, distributes, releases, issues, or produces the resource. This property will be used to formulate the citation, so consider the prominence of the role.</xs:documentation>								</xs:annotation>								<xs:complexType>									<xs:simpleContent>										<xs:extension base="xs:string">											<xs:attribute name="publisherIdentifier" type="xs:anyURI" use="required">												<xs:annotation>													<xs:documentation>Uniquely identifies the publisher, according to various schemes.</xs:documentation>												</xs:annotation>											</xs:attribute>											<xs:attribute name="publisherIdentifierScheme" type="xs:string" use="required"/>											<xs:attribute name="schemeURI" type="xs:anyURI" use="required"/>											<xs:attribute name="lang" fixed="en">												<xs:simpleType>													<xs:restriction base="xs:language">														<xs:enumeration value="en"/>													</xs:restriction>												</xs:simpleType>											</xs:attribute>										</xs:extension>									</xs:simpleContent>								</xs:complexType>							</xs:element>						</xs:sequence>					</xs:complexType>				</xs:element>				<xs:element name="geoLocations" minOccurs="0" maxOccurs="unbounded">					<xs:annotation>						<xs:documentation>Spatial region or named place where the sample was gathered or about which the data is focused.</xs:documentation>					</xs:annotation>					<xs:complexType>						<xs:sequence>							<xs:element name="geoLocationPlace" minOccurs="0" maxOccurs="unbounded">								<xs:annotation>									<xs:documentation>"Where was the sample acquired relative to the Earth (or another celestial body...). Some samples might be 'non-geographic': mineral specimen, synthetic material. Spatial region or named place where the data was gathered or about which the data is focused."</xs:documentation>								</xs:annotation>								<xs:complexType>									<xs:simpleContent>										<xs:extension base="xs:string">											<xs:attribute name="lang" fixed="en">												<xs:simpleType>													<xs:restriction base="xs:language">														<xs:enumeration value="en"/>													</xs:restriction>												</xs:simpleType>											</xs:attribute>										</xs:extension>									</xs:simpleContent>								</xs:complexType>							</xs:element>							<xs:element name="coordinateSystem" default="WGS84">								<xs:simpleType>									<xs:restriction base="xs:string">										<xs:enumeration value="WGS84"/>									</xs:restriction>								</xs:simpleType>							</xs:element>							<xs:element name="geoLocationPoint" type="daci:point" minOccurs="0" maxOccurs="1">								<xs:annotation>									<xs:documentation>"A point contains a single longitude-latitude pair.Use WGS 84 (World Geodetic System) coordinates and use only decimal numbers for coordinates."</xs:documentation>								</xs:annotation>							</xs:element>							<xs:element name="geoLocationBox" type="daci:box" minOccurs="0" maxOccurs="1">								<xs:annotation>									<xs:documentation>"A box is defined by two geographic points. Left low corner and right upper corner. Each point is defined by its longitude and latitude.Use WGS 84 (World Geodetic System) coordinates and use only decimal numbers for coordinates."</xs:documentation>								</xs:annotation>							</xs:element>							<xs:element name="geoLocationPolygon" minOccurs="0">								<xs:annotation>									<xs:documentation>A drawn polygon area, defined by a set of points and lines connecting the points in a closed chain. A polygon is delimited by geographic points. Each point is defined by a longitude-latitude pair. The last point should be the same as the first point.</xs:documentation>								</xs:annotation>								<xs:complexType>									<xs:sequence>										<xs:element name="polygonPoint" type="daci:point" minOccurs="4" maxOccurs="unbounded"/>									</xs:sequence>								</xs:complexType>							</xs:element>						</xs:sequence>					</xs:complexType>				</xs:element>				<xs:element name="entityTypeClassifications">					<xs:annotation>						<xs:documentation>							Wrapper to hold all material and classification information about the resource						</xs:documentation>					</xs:annotation>					<xs:complexType>						<xs:sequence>							<xs:element name="resourceType">								<xs:simpleType>									<xs:restriction base="xs:string">										<xs:enumeration value="Feature"/>										<xs:enumeration value="Sample"/>										<xs:enumeration value="Collection"/>									</xs:restriction>								</xs:simpleType>							</xs:element>							<xs:element name="classification">								<xs:complexType>									<xs:simpleContent>										<xs:extension base="xs:string">											<xs:attribute name="subjectScheme" type="xs:string" use="optional"/>											<xs:attribute name="schemeURI" type="xs:anyURI" use="optional"/>											<xs:attribute name="valueURI" type="xs:anyURI" use="optional"/>											<xs:attribute name="classificationCode" type="xs:string" use="optional"/>											<xs:attribute name="lang" fixed="en">												<xs:simpleType>													<xs:restriction base="xs:language">														<xs:enumeration value="en"/>													</xs:restriction>												</xs:simpleType>											</xs:attribute>										</xs:extension>									</xs:simpleContent>								</xs:complexType>							</xs:element>							<xs:element name="material" minOccurs="0">								<xs:annotation>									<xs:documentation>Categorize the material that composes to the sample, e.g. water, granite, tissue. Idea is to create a high-level cross-domain vocabulary. (1..N, nillable). 'lot' type samples (dredge haul, drill core) may have multiple materials included. Material may be categorized under different schemes. Implementation should be a 'scoped' name (vocabulary URI, concept/term URI, label for display). If none of the materials available via the VOC are suitable, you can select ‘Other’ here to use the free-text field in ‘alternateMaterial’ for your entry</xs:documentation>								</xs:annotation>								<xs:complexType>									<xs:simpleContent>										<xs:extension base="xs:string">											<xs:attribute name="subjectScheme" type="xs:string" use="optional"/>											<xs:attribute name="schemeURI" type="xs:anyURI" use="optional"/>											<xs:attribute name="valueURI" type="xs:anyURI" use="optional"/>											<xs:attribute name="classificationCode" type="xs:string" use="optional"/>											<xs:attribute name="lang" fixed="en">												<xs:simpleType>													<xs:restriction base="xs:language">														<xs:enumeration value="en"/>													</xs:restriction>												</xs:simpleType>											</xs:attribute>										</xs:extension>									</xs:simpleContent>								</xs:complexType>							</xs:element>							<xs:element name="alternateMaterial" minOccurs="0" maxOccurs="unbounded">								<xs:annotation>									<xs:documentation>element to alow material classification for resources that do not match the availabel material vocabulrys.</xs:documentation>								</xs:annotation>								<xs:complexType>									<xs:simpleContent>										<xs:extension base="xs:string">											<xs:attribute name="subjectScheme" type="xs:string" use="optional"/>											<xs:attribute name="schemeURI" type="xs:anyURI" use="optional"/>											<xs:attribute name="valueURI" type="xs:anyURI" use="optional"/>											<xs:attribute name="classificationCode" type="xs:string" use="optional"/>											<xs:attribute name="lang" fixed="en">												<xs:simpleType>													<xs:restriction base="xs:language">														<xs:enumeration value="en"/>													</xs:restriction>												</xs:simpleType>											</xs:attribute>										</xs:extension>									</xs:simpleContent>								</xs:complexType>							</xs:element>							<xs:element name="description" minOccurs="0" maxOccurs="unbounded">								<xs:annotation>									<xs:documentation>Descriptive text about the sample. Free text, anything else that might be useful to know about the sample at its 'birth'. </xs:documentation>								</xs:annotation>								<xs:complexType>									<xs:simpleContent>										<xs:extension base="xs:string">											<xs:attribute name="descriptionType" use="required">												<xs:annotation>													<xs:documentation>type of the description, enum list</xs:documentation>												</xs:annotation>												<xs:simpleType>													<xs:restriction base="daci:descriptionType">														<xs:enumeration value="Abstract"/>														<xs:enumeration value="Methods"/>														<xs:enumeration value="SeriesInformation"/>														<xs:enumeration value="TableOfContents"/>														<xs:enumeration value="TechnicalInfo"/>														<xs:enumeration value="Other"/>													</xs:restriction>												</xs:simpleType>											</xs:attribute>											<xs:attribute name="lang" use="required">												<xs:simpleType>													<xs:restriction base="xs:language">														<xs:enumeration value="en"/>														<xs:enumeration value="de"/>													</xs:restriction>												</xs:simpleType>											</xs:attribute>										</xs:extension>									</xs:simpleContent>								</xs:complexType>							</xs:element>						</xs:sequence>					</xs:complexType>				</xs:element>				<xs:element name="dates">					<xs:annotation>						<xs:documentation>contains all the dates, in regads to the sampel and the metadata</xs:documentation>					</xs:annotation>					<xs:complexType>						<xs:sequence>							<